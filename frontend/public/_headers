/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(self)
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # CSP allows: self for scripts/styles/images, FontAwesome (cdnjs/use.fontawesome), Google Fonts, Stripe Checkout
  # 'unsafe-inline' on style-src is required by the existing inline style attributes throughout the templates;
  # tighten by extracting them to a stylesheet in a follow-up.
  Content-Security-Policy: default-src 'self'; script-src 'self' https://js.stripe.com https://cdnjs.cloudflare.com 'unsafe-inline'; style-src 'self' https://cdnjs.cloudflare.com https://use.fontawesome.com https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://cdnjs.cloudflare.com https://use.fontawesome.com https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com https://cdnjs.cloudflare.com; frame-src 'self' https://js.stripe.com https://hooks.stripe.com; frame-ancestors 'none'; form-action 'self' https://checkout.stripe.com; base-uri 'self'; media-src 'self' blob:; worker-src 'self'

/api/*
  Cache-Control: no-store

# Service worker + shell must always revalidate. The SW does network-first
# for the shell already, but its fetch() still respects the browser HTTP
# cache — so without no-cache here a freshly-activated v2 SW can still
# serve a 4-hour-old app.js. Forces immediate propagation of every shell
# change. Shell files are tiny so revalidation cost is negligible.
/checkin/sw.js
  Cache-Control: no-cache, must-revalidate
/checkin/app.js
  Cache-Control: no-cache, must-revalidate
/checkin/app.css
  Cache-Control: no-cache, must-revalidate
/checkin/index.html
  Cache-Control: no-cache, must-revalidate
/checkin/
  Cache-Control: no-cache, must-revalidate
